# App
NODE_ENV=development
PORT=3000
# Puerto expuesto en el host para la API (cámbialo si 3000 está ocupado en tu máquina)
API_HOST_PORT=3000
LOG_LEVEL=debug
CORS_ORIGIN=*

# Postgres (local docker-compose usa estos valores)
DATABASE_URL=postgres://tasks:tasks@postgres:5432/tasks_db

# Redis (local docker-compose)
REDIS_URL=redis://redis:6379

# JWT (min 32 caracteres). Genera uno real con: openssl rand -hex 32
JWT_SECRET=change-me-please-at-least-32-chars-long
JWT_EXPIRES_IN=1h

# Cache
CACHE_TTL_SECONDS=60
